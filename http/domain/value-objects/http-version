#include <cctype>
#include <string>

#ifndef _C_HTTP_VERSION_
#define _C_HTTP_VERSION_ 1

class HttpVersion
{
private:
    static constexpr char HTTP[] = "HTTP";

    unsigned int major = 0;
    unsigned int minor = 0;
    bool invalid = false;

    /// @brief Checks if the major and minor version of http protocol are valid
    /// @return true if valid
    bool isMajorMinorValid()
    {
        switch (major)
        {
        case 0:
            return minor == 9;

        case 1:
            return minor == 0 || minor == 1;

        case 2:
        case 3:
            return minor == 0;
        }
        return false;
    }

public:
    /// @brief Parses a string containg http protocol with versions
    /// @param s String containing protocol and version
    HttpVersion(const char *s)
    {
        int i = 0;
        while (isspace(*s))
            s++;

        // Parse "http"
        while (HTTP[i] != '\0' && toupper(*s++) == HTTP[i++])
            ;
        if (invalid = (HTTP[i] != '\0' || *s++ != '/'))
            return;

        // Parse the major version
        if (*s != '\0' && isdigit(*s))
            major = *s++ - '0';
        else
        {
            invalid = true;
            return;
        }

        // Parse the minor version if given
        if (*s == '.')
        {
            if (*++s != '\0' && isdigit(*s))
                minor = *s++ - '0';
            else
            {
                invalid = true;
                return;
            }
        }

        // if major and minor not suitable, invalid
        invalid = *s != '\0' && !isspace(*s) || !isMajorMinorValid();
    }

    /// @brief Check if the parsed result is invalid
    /// @return true if invalid
    bool isInvalid() const
    {
        return invalid;
    }

    /// @brief Gets the major version parsed from the protocol
    /// @return 0, 1, 2, 3
    int majorVersion() const
    {
        return major;
    }

    /// @brief Gets the minor version parsed from the protocol
    /// @return 0, 1, 9
    int minorVersion() const
    {
        return minor;
    }
};

#endif